<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Espace Admin - CabinetMédical</title>
    <link rel="stylesheet" href="style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>

    <header>
        <div class="brand"><i class="fa-solid fa-shield-halved"></i> CABINET<span>MÉDICAL</span> <small>[ADMIN]</small></div>
        <button onclick="sortir()" class="btn-logout"><i class="fa-solid fa-right-from-bracket"></i> Déconnexion</button>
    </header>

    <div class="container">
        <div class="top-bar">
            <h2>Indemnités et Calcul des Soins</h2>
        </div>

        <div class="admin-grid">
            <div class="stat-card">
                <div class="stat-icon"><i class="fa-solid fa-road"></i></div>
                <div class="stat-info"><label>Seuil Km</label><span>20 Km / Jour</span></div>
            </div>
            <div class="stat-card">
                <div class="stat-icon"><i class="fa-solid fa-money-bill-wave"></i></div>
                <div class="stat-info"><label>Tarif Km Supp.</label><span>2.00 DH</span></div>
            </div>
            <div class="stat-card">
                <div class="stat-icon"><i class="fa-solid fa-clock"></i></div>
                <div class="stat-info"><label>Prime Pénibilité</label><span>10.00 DH</span></div>
            </div>
        </div>

        <div class="table-wrapper" style="margin-bottom: 30px;">
            <div class="filter-bar">
                <div>
                    <label>Mois d'analyse :</label><br>
                    <input type="month" id="monthPick" onchange="calculerIndemnites()">
                </div>
                <div>
                    <label>Forfait Base (DH) :</label><br>
                    <input type="number" id="forfaitInput" value="1500" min="0" oninput="calculerIndemnites()">
                </div>
            </div>
        </div>

        <div class="table-wrapper">
            <table>
                <thead>
                    <tr>
                        <th>Infirmier(e)</th>
                        <th>Distance Totale</th>
                        <th>Km Supp.</th>
                        <th>Soins Pénibles</th>
                        <th>Détails</th>
                        <th>Total</th>
                    </tr>
                </thead>
                <tbody id="adminTableBody"></tbody>
            </table>
        </div>
    </div>

    <script>
        const sess = JSON.parse(localStorage.getItem('activeUser'));
        if (!sess || sess.role !== 'admin') window.location.href = 'index.html';
        
        document.getElementById('monthPick').value = "2026-06";

        function calculerIndemnites(){
            const selMonth = document.getElementById('monthPick').value;
            const forfaitBase = parseFloat(document.getElementById('forfaitInput').value) || 0;
            
            const allSoins = JSON.parse(localStorage.getItem('soins')) || [];
            const allUsers = JSON.parse(localStorage.getItem('users')) || [];
            const infirmiers = allUsers.filter(u => u.role === 'infirmier');
            
            const table = document.getElementById('adminTableBody');
            table.innerHTML = '';
            
            infirmiers.forEach(inf => {
                const mine = allSoins.filter(s => s.infirmierId === inf.id && s.date.startsWith(selMonth));
                
                let totalKmDuMois = 0;
                let totalKmSuppRemuneres = 0;
                let nbSoinsPenibles = 0;
                let kmsParJour = {};

                mine.forEach(s => {
                    totalKmDuMois += s.distanceKm;
                    if (!kmsParJour[s.date]) kmsParJour[s.date] = 0;
                    kmsParJour[s.date] += s.distanceKm;

                    const [hD, mD] = s.heureDebut.split(':').map(Number);
                    const [hF, mF] = s.heureFin.split(':').map(Number);
                    if (((hF * 60 + mF) - (hD * 60 + mD)) > 30) nbSoinsPenibles++;
                });

                for (let jour in kmsParJour) {
                    if (kmsParJour[jour] > 20) totalKmSuppRemuneres += (kmsParJour[jour] - 20);
                }

                const totalFinal = forfaitBase + (totalKmSuppRemuneres * 2) + (nbSoinsPenibles * 10);

                table.innerHTML += `
                    <tr>
                        <td style="font-weight:600;"><i class="fa-solid fa-user-circle" style="margin-right:8px; color:#0ea5e9;"></i>${inf.nom}</td>
                        <td>${totalKmDuMois} km</td>
                        <td><span class="badge ${totalKmSuppRemuneres > 0 ? 'badge-success' : 'badge-neutral'}">${totalKmSuppRemuneres} km</span></td>
                        <td>${nbSoinsPenibles} soin(s)</td>
                        <td style="font-size:11px; color:#64748b;">${totalFinal.toFixed(2)} DH (Base + Supp)</td>
                        <td class="bonus-amt">${totalFinal.toFixed(2)} DH</td>
                    </tr>
                `;
            });
        }

        function sortir() {
            localStorage.removeItem('activeUser');
            window.location.href='index.html';
        }
        
        calculerIndemnites();
    </script>
</body>
</html> 